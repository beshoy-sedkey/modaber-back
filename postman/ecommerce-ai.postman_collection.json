                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "customer.created",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_SALLA_WEBHOOK_SECRET"
              }
            ],
            "url": "{{baseUrl}}/webhooks/salla",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"customer.created\",\n  \"merchant\": 12345,\n  \"data\": {\n    \"id\": 201,\n    \"first_name\": \"Fatima\",\n    \"last_name\": \"Al-Rashidi\",\n    \"email\": \"fatima@test.com\",\n    \"mobile\": \"+966509876543\",\n    \"city\": \"Jeddah\",\n    \"country\": \"SA\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "app.uninstalled",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_SALLA_WEBHOOK_SECRET"
              }
            ],
            "url": "{{baseUrl}}/webhooks/salla",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"app.uninstalled\",\n  \"merchant\": 12345,\n  \"data\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "description": "Merchant uninstalled the app. Deactivates the merchant and sets needsReauth=true."
          }
        },
        {
          "name": "app.subscription.started",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_SALLA_WEBHOOK_SECRET"
              }
            ],
            "url": "{{baseUrl}}/webhooks/salla",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"app.subscription.started\",\n  \"merchant\": 12345,\n  \"data\": { \"plan\": \"pro\" }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "app.subscription.canceled",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer YOUR_SALLA_WEBHOOK_SECRET"
              }
            ],
            "url": "{{baseUrl}}/webhooks/salla",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"app.subscription.canceled\",\n  \"merchant\": 12345,\n  \"data\": {}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
      "name": "🔄 Salla Sync",
      "item": [
        {
          "name": "Trigger Manual Product Sync",
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/platform/salla/sync",
            "description": "Manually triggers full product sync from Salla. Requires JWT. Paginates through all products and deactivates stale ones. Cron runs every hour automatically."
          }
        }
      ]
    },
    {
      "name": "📦 Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "category",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Returns paginated products for the authenticated merchant. Supports category and search filters."
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/PRODUCT_ID",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "PRODUCT_ID"
              ]
            },
            "description": "Replace PRODUCT_ID with an ID from the list response."
          }
        }
      ]
    },
    {
      "name": "🛒 Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "pending",
                  "disabled": true,
                  "description": "pending|confirmed|shipped|delivered|cancelled"
                }
              ]
            },
            "description": "Returns paginated orders with customer info and items. Filter by status optionally."
          }
        },
        {
          "name": "List Orders — Pending Only",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?status=pending",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
          }
        },
        {
          "name": "List Orders — Delivered",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?status=delivered",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "delivered"
                }
              ]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders/ORDER_ID",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "ORDER_ID"
              ]
            },
            "description": "Returns full order with customer, items, product names, and shipment info."
          }
        }
      ]
    },
    {
      "name": "🚚 Shipping",
      "item": [
        {
          "name": "List Carriers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/shipping/carriers",
            "description": "List all shipping carriers configured for the merchant"
          }
        },
        {
          "name": "Add Carrier",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/shipping/carriers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carrierName\": \"aramex\",\n  \"apiKey\": \"your-aramex-api-key\",\n  \"isActive\": true,\n  \"priority\": 1,\n  \"coverageAreas\": { \"regions\": [\"riyadh\", \"jeddah\"] }\n}"
            },
            "description": "Add a new shipping carrier. API key is encrypted at rest."
          }
        },
        {
          "name": "Update Carrier",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/shipping/carriers/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false,\n  \"priority\": 2\n}"
            },
            "description": "Update carrier configuration. Only own carriers (by merchantId) can be updated."
          }
        },
        {
          "name": "Delete Carrier",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/shipping/carriers/:id",
            "description": "Remove a carrier. Only own carriers (by merchantId) can be deleted."
          }
        },
        {
          "name": "List Shipments",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/shipping/shipments?page=1&limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "shipping",
                "shipments"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
