          }
        },
        {
          "name": "Send Message (HTTP fallback)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/widget/{{apiKey}}/message",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{sessionId}}\",\n  \"message\": \"I'm looking for a gift under 200 SAR for a birthday\"\n}"
            },
            "description": "HTTP POST fallback when Socket.IO is unavailable. Returns full response (non-streaming). For real-time streaming use Socket.IO instead."
          }
        },
        {
          "name": "Socket.IO — Connect & Chat (instructions)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/docs",
            "description": "Socket.IO endpoint: ws://localhost:3000/chat\n\nConnect:\n  socket = io('http://localhost:3000/chat', {\n    auth: { apiKey: '{{apiKey}}', sessionId: '{{sessionId}}' }\n  });\n\nSend message:\n  socket.emit('message', { message: 'Find me a red handbag under 500 SAR' });\n\nReceive streaming tokens:\n  socket.on('response_token', (data) => process.stdout.write(data.token));\n  socket.on('response_complete', () => console.log('Done'));\n\nTyping indicator:\n  socket.emit('typing', { isTyping: true });\n\nDisconnect:\n  socket.emit('disconnect_chat');"
          }
        }
      ]
    },
